{
  "expo": {
    "name": "Relevamiento Chaco",
    "slug": "relevamiento-chaco",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/app-icon-chaco.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/brand/logo-chaco.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "La camara se usa para escanear el DNI argentino y capturar documentacion del relevamiento."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/app-icon-chaco.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pablocao.relevamientochaco",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/brand/app-icon-chaco.png"
    },
    "extra": {
      "eas": {
        "projectId": "9bd4ef7a-6e9a-4110-91c1-3c07565eef33"
      }
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "La camara se usa para escanear el DNI argentino y capturar documentacion del relevamiento."
        }
      ],
      "expo-image-picker",
      "expo-screen-orientation",
      "expo-sqlite",
      "expo-font",
      "expo-secure-store"
    ]
  }
}
